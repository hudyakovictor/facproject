{
  "schema": "forensic-ui-navigation-v2-focused",
  "scope": ["calibration_configs", "pairwise_face_testing", "geometry_skin_comparison", "morphing"],
  "excluded": ["main_dataset_browser", "investigation_timeline", "main_analysis_reports"],
  "routes": [
    {"path": "/doctor", "id": "doctor", "label": "System Doctor"},
    {"path": "/calibration", "id": "calibration", "label": "Calibration Studio"},
    {"path": "/calibration/:id/workbench/:pose/:zone", "id": "zone-calibration", "label": "Zone Workbench"},
    {"path": "/compare", "id": "compare", "label": "Comparison Lab"},
    {"path": "/compare/:sessionId", "id": "comparison-session", "label": "A/B Comparison"},
    {"path": "/morph/:sessionId", "id": "morph", "label": "Morph Studio"},
    {"path": "/runs", "id": "runs", "label": "Runs & Logs"},
    {"path": "/settings", "id": "settings", "label": "Settings"}
  ],
  "calibrationStates": ["draft", "running", "failed", "passed", "frozen"],
  "comparisonStates": ["draft", "processing", "ready", "limited", "failed"],
  "pairComparability": ["recommended", "comparable", "limited_pose", "limited_quality", "not_measurable"],
  "meshModes": ["identity_only", "identity_expression", "wireframe", "displacement_heatmap"],
  "textureModes": ["flat", "synthetic_a", "synthetic_b", "synthetic_crossfade", "analytical_overlap"],
  "morphRegions": ["full_face", "forehead", "eyes", "nose", "cheekbones", "jaw", "chin"],
  "guards": [
    "synthetic UV cannot enter skin metrics",
    "frozen calibration profile cannot be edited",
    "near-duplicate clusters cannot cross calibration splits",
    "morph requires identical topology hash",
    "identity-only and expression-inclusive metrics remain separate",
    "cross-pose skin comparisons are marked limited",
    "visual exaggeration never changes numeric metrics",
    "UI does not output identity probability",
    "original photos are read-only"
  ]
}
